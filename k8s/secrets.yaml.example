# Copy to k8s/secrets.yaml, fill in values, then: kubectl apply -f k8s/secrets.yaml
# Never commit k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: patient-tracker-secrets
type: Opaque
stringData:
  database-url: "postgresql://patient_user:CHANGE_ME@postgres-service:5432/patient_tracker"
  postgres-password: "CHANGE_ME"
